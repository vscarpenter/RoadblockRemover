{
  "name": "roadblock-remover",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "clean": "rm -rf .next out",
    "build": "bun run clean && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "deploy": "bun run build && aws s3 sync out/ s3://roadblocks.vinny.dev --delete && aws cloudfront create-invalidation --distribution-id E38A5WXLD4M0J3 --paths '/*'"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "framer-motion": "^12.36.0",
    "next": "^16.1.6",
    "pocketbase": "^0.26.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@tailwindcss/typography": "^0.5.19",
    "tailwindcss": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "eslint": "^10.0.3",
    "eslint-config-next": "^16.1.6",
    "jest": "^30.3.0",
    "@jest/types": "^30.3.0",
    "ts-jest": "^29.4.6",
    "jest-environment-jsdom": "^30.3.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1"
  }
}
